# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_time_machines
DB_USER=postgres
DB_PASSWORD=your_database_password_here
DB_DIALECT=postgres

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Node Environment
NODE_ENV=development

# Server Configuration
BACKEND_PORT=5000
FRONTEND_PORT=3000

# Python Service Configuration
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_SERVICE_PORT=8000

# CORS Settings
CORS_ORIGIN=http://localhost:3000

# Webhook Security (HMAC-SHA256 shared secret for incoming webhooks)
# Set to a long, random string in production.
WEBHOOK_SECRET=your_webhook_secret_here

# Graceful shutdown timeout in milliseconds (default: 10000)
SHUTDOWN_TIMEOUT_MS=10000

# OpenClaw Integration
OPENCLAW_API_KEY=your_openclaw_api_key_here

# Autonomous Monitoring
# Fractional loss increase that triggers a drift alert (default: 0.05 = 5%)
DRIFT_THRESHOLD=0.05
